# Wildberries API
WB_API_KEY=your_wildberries_api_key_here

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=wb_analytics
MYSQL_USER=wb_user
MYSQL_PASSWORD=wb_password
MYSQL_ROOT_PASSWORD=rootpassword

# App Configuration
APP_PORT=3000
NODE_ENV=development

# Telegram Auth (create bot via @BotFather, then /setdomain to bidberry.animeenigma.ru)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_NAME=your_bot_username

# Telegram OpenID Connect login (website sign-in).
# In @BotFather → Bot Settings → Web Login: register the Allowed URL
#   https://bidberry.animeenigma.ru
# and the redirect URI
#   https://bidberry.animeenigma.ru/api/auth/telegram/oidc/callback
# BotFather then shows the Client ID + Client Secret to put here.
TELEGRAM_OIDC_CLIENT_ID=your_oidc_client_id
TELEGRAM_OIDC_CLIENT_SECRET=your_oidc_client_secret
# Pin the public origin used to build redirect_uri (must match BotFather exactly).
OAUTH_REDIRECT_BASE=https://bidberry.animeenigma.ru

# JWT
JWT_SECRET=generate-random-secret-here
JWT_ACCESS_TTL=24h

# Scheduler (intervals in minutes)
SCHEDULER_KEYWORD_CHECK_INTERVAL=360
SCHEDULER_SALES_SYNC_INTERVAL=720
SCHEDULER_BIDDER_INTERVAL=30
