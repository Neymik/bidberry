  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "dayjs": "^1.11.19",
    "fflate": "^0.8.2",
    "hono": "^4.11.5",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.16.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
